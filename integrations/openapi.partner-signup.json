{
  "openapi": "3.1.0",
  "info": {
    "title": "Partner Command Center Partner Signup API",
    "version": "1.0.0",
    "description": "GPT Action contract for submitting partner signups into Partner Command Center."
  },
  "servers": [
    {
      "url": "https://partner-command-center-rho.vercel.app"
    }
  ],
  "paths": {
    "/api/partner-signup": {
      "post": {
        "operationId": "submitPartnerSignup",
        "summary": "Submit a partner signup",
        "description": "Creates or updates a partner signup from ChatGPT, classifies partner type and tier, stores the partner profile, and logs a Partner Event. Not for borrower applications.",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitPartnerSignupRequest"
              },
              "examples": {
                "creator_affiliate_partner_signup": {
                  "summary": "creator_affiliate partner signup",
                  "value": {
                    "partner": {
                      "first_name": "Alex",
                      "last_name": "Rivera",
                      "email": "alex@example.com",
                      "phone": "+1-555-010-1000",
                      "company": "Rivera Growth Media",
                      "website": "https://example.com",
                      "partner_type_claimed": "creator_affiliate",
                      "audience": "small business owners, freelancers, and startup operators",
                      "industry": "content, media, and business education",
                      "location": "Washington, DC",
                      "funding_experience": "Some experience referring business owners to funding resources.",
                      "current_tools": "Newsletter, YouTube, Substack, CRM, affiliate links",
                      "traffic_or_network_size": "5,000 email subscribers and 12,000 social followers",
                      "referral_volume_estimate": "5 to 10 warm referrals per month",
                      "desired_partner_role": "Promote funding readiness resources and refer qualified business owners",
                      "notes": "Interested in affiliate tracking, compliant content angles, and onboarding resources.",
                      "source": "gpt_action"
                    }
                  }
                },
                "funding_broker_partner_signup": {
                  "summary": "funding_broker partner signup",
                  "value": {
                    "partner": {
                      "first_name": "Morgan",
                      "last_name": "Lee",
                      "email": "morgan@example.com",
                      "phone": "+1-555-010-2200",
                      "company": "Lee Capital Referrals",
                      "website": "https://broker.example.com",
                      "partner_type_claimed": "funding_broker",
                      "audience": "business owners seeking working capital education and funding readiness help",
                      "industry": "commercial finance and small business advisory",
                      "location": "Atlanta, GA",
                      "funding_experience": "Experienced broker with active client conversations and a weekly referral process.",
                      "current_tools": "CRM, email outreach, referral forms, partner links",
                      "traffic_or_network_size": "Local network plus broker relationships",
                      "referral_volume_estimate": "10 to 20 qualified referrals per month",
                      "desired_partner_role": "Refer qualified business owners and use partner tracking links",
                      "notes": "Ready to launch this month and wants broker onboarding resources.",
                      "source": "gpt_action"
                    }
                  }
                },
                "referral_partner_signup": {
                  "summary": "referral_partner signup",
                  "value": {
                    "partner": {
                      "first_name": "Taylor",
                      "last_name": "Nguyen",
                      "email": "taylor@example.com",
                      "phone": "+1-555-010-3300",
                      "company": "Nguyen Business Services",
                      "website": "https://services.example.com",
                      "partner_type_claimed": "referral_partner",
                      "audience": "local service businesses and independent operators",
                      "industry": "business consulting",
                      "location": "Richmond, VA",
                      "funding_experience": "Occasionally refers clients to trusted finance contacts.",
                      "current_tools": "Email, LinkedIn, spreadsheet tracker",
                      "traffic_or_network_size": "300 close business contacts",
                      "referral_volume_estimate": "1 to 3 warm referrals per month",
                      "desired_partner_role": "Make warm introductions when clients need funding readiness support",
                      "notes": "Wants a simple referral partner path with clear next steps.",
                      "source": "gpt_action"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Partner signup stored",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PartnerSignupResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "405": {
            "description": "Method not allowed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "502": {
            "description": "Notion request failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "PARTNER_COMMAND_API_KEY",
        "description": "Use Authorization: Bearer <PARTNER_COMMAND_API_KEY>."
      }
    },
    "schemas": {
      "SubmitPartnerSignupRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "partner"
        ],
        "properties": {
          "partner": {
            "$ref": "#/components/schemas/PartnerSignup"
          }
        }
      },
      "PartnerSignup": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "email"
        ],
        "properties": {
          "first_name": {
            "type": "string",
            "description": "Partner first name."
          },
          "last_name": {
            "type": "string",
            "description": "Partner last name."
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Partner email address."
          },
          "phone": {
            "type": "string",
            "description": "Partner phone number."
          },
          "company": {
            "type": "string",
            "description": "Partner company, brand, or organization."
          },
          "website": {
            "type": "string",
            "format": "uri",
            "description": "Partner website, profile, or brand URL."
          },
          "partner_type_claimed": {
            "type": "string",
            "description": "How the partner describes their role.",
            "examples": [
              "creator_affiliate",
              "funding_broker",
              "referral_partner",
              "cpa_bookkeeper",
              "real_estate_professional",
              "ecommerce_consultant",
              "community_connector",
              "vendor_partner",
              "strategic_partner"
            ]
          },
          "audience": {
            "type": "string",
            "description": "Who the partner serves or reaches."
          },
          "industry": {
            "type": "string",
            "description": "Partner industry or operating niche."
          },
          "location": {
            "type": "string",
            "description": "Partner city, region, or market."
          },
          "funding_experience": {
            "type": "string",
            "description": "Partner experience referring people to funding education, resources, or trusted contacts."
          },
          "current_tools": {
            "type": "string",
            "description": "Tools, platforms, or channels the partner already uses."
          },
          "traffic_or_network_size": {
            "type": "string",
            "description": "Approximate audience, client base, or network size."
          },
          "referral_volume_estimate": {
            "type": "string",
            "description": "Estimated warm referral volume."
          },
          "desired_partner_role": {
            "type": "string",
            "description": "How the partner wants to participate."
          },
          "notes": {
            "type": "string",
            "description": "Additional partner context."
          },
          "source": {
            "type": "string",
            "description": "Signup source. Use gpt_action for ChatGPT submissions.",
            "default": "gpt_action"
          }
        }
      },
      "PartnerSignupResponse": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "data": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "action": {
                "type": "string",
                "const": "submitPartnerSignup"
              },
              "result": {
                "type": "string",
                "examples": [
                  "created_or_updated"
                ]
              },
              "partner_id": {
                "type": "string",
                "examples": [
                  "MS-P-20260708120000-ABC12345"
                ]
              },
              "partner": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "partner_id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "company": {
                    "type": "string"
                  },
                  "partner_type": {
                    "type": "string",
                    "enum": [
                      "funding_broker",
                      "referral_partner",
                      "affiliate_partner",
                      "center_of_influence",
                      "professional_service_provider",
                      "community_connector",
                      "internal_operator",
                      "unknown"
                    ]
                  },
                  "audience": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "intake_received",
                      "needs_review"
                    ]
                  },
                  "tier": {
                    "type": "string",
                    "enum": [
                      "tier_1",
                      "tier_2",
                      "tier_3",
                      "manual_review",
                      "watchlist"
                    ]
                  },
                  "onboarding_path": {
                    "type": "string",
                    "enum": [
                      "broker_fast_start",
                      "affiliate_launch_path",
                      "coi_relationship_path",
                      "referral_partner_path",
                      "manual_review_path"
                    ]
                  },
                  "resource_recommendations": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "campaign_recommendations": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "notion_page": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string",
                    "format": "uri"
                  }
                }
              }
            }
          }
        }
      },
      "ApiError": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "ok": {
            "type": "boolean",
            "const": false
          },
          "error": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "details": {}
            }
          }
        }
      }
    }
  }
}
