{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://partner-command-center-rho.vercel.app/schemas/partner-attributed-lead.schema.json",
  "title": "Partner-Attributed Funding Lead Router Request",
  "description": "Canonical trusted request contract for POST /api/lead-router. The embedded lead mirrors the Am I Fundable funding-readiness contract. Partner signup remains on /api/router and /api/partner-signup.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "idempotency_key",
    "source_system",
    "submitted_at",
    "lead"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 8,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{7,199}$",
      "description": "Stable retry key. Reusing the key with the same payload must replay the original result."
    },
    "source_system": {
      "type": "string",
      "enum": [
        "am_i_fundable",
        "fundstack_ai",
        "vertical_funnel",
        "embed_widget",
        "partner_landing_page",
        "gpt_action",
        "operator_entry",
        "legacy_partner_dashboard"
      ]
    },
    "source_event_id": {
      "type": ["string", "null"],
      "maxLength": 200,
      "description": "Optional immutable event or submission identifier from the source system."
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "lead": {
      "$ref": "#/$defs/lead"
    },
    "submission_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "request_id": {"type": ["string", "null"], "maxLength": 200},
        "adapter_version": {"type": ["string", "null"], "maxLength": 80},
        "legacy_payload": {"type": "boolean", "default": false},
        "first_touch": {"$ref": "#/$defs/attributionTouch"},
        "latest_touch": {"$ref": "#/$defs/attributionTouch"}
      }
    }
  },
  "$defs": {
    "lead": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lead_id",
        "applicant",
        "answers",
        "score_result",
        "lead_priority",
        "primary_funding_family",
        "secondary_funding_families",
        "risks",
        "strengths",
        "recommended_documents",
        "next_steps",
        "manual_review_recommended",
        "partner_id",
        "tracking_link_id",
        "campaign_id",
        "widget_id",
        "source_url",
        "source_asset",
        "utm_source",
        "utm_medium",
        "utm_campaign",
        "utm_term",
        "utm_content",
        "consent",
        "review_status",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "lead_id": {"type": "string", "minLength": 8, "maxLength": 120, "pattern": "^lead_[A-Za-z0-9_-]+$"},
        "applicant": {"$ref": "#/$defs/applicant"},
        "answers": {"$ref": "#/$defs/answers"},
        "score_result": {"$ref": "#/$defs/scoreResult"},
        "lead_priority": {"type": "string", "enum": ["hot", "warm", "nurture", "education", "manual_review"]},
        "primary_funding_family": {"$ref": "#/$defs/fundingFamily"},
        "secondary_funding_families": {"type": "array", "maxItems": 5, "items": {"$ref": "#/$defs/fundingFamily"}},
        "risks": {"type": "array", "maxItems": 20, "items": {"type": "string", "minLength": 1, "maxLength": 300}},
        "strengths": {"type": "array", "maxItems": 20, "items": {"type": "string", "minLength": 1, "maxLength": 300}},
        "recommended_documents": {"type": "array", "maxItems": 25, "items": {"$ref": "#/$defs/documentItem"}},
        "next_steps": {"type": "array", "maxItems": 20, "items": {"$ref": "#/$defs/nextStep"}},
        "manual_review_recommended": {"type": "boolean"},
        "partner_id": {
          "type": ["string", "null"],
          "minLength": 3,
          "maxLength": 120,
          "pattern": "^MS-P-[A-Za-z0-9_-]+$",
          "description": "Null for direct or unresolved traffic. Credited only after Partners CRM validation."
        },
        "tracking_link_id": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 120,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,119}$",
          "description": "Referral Token or serialized Tracking Link ID resolved against the Tracking Links database."
        },
        "campaign_id": {"type": ["string", "null"], "maxLength": 120, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,119}$"},
        "widget_id": {"type": ["string", "null"], "maxLength": 120, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,119}$"},
        "source_url": {"type": "string", "format": "uri", "maxLength": 2048},
        "source_asset": {"type": "string", "minLength": 1, "maxLength": 160, "pattern": "^[a-z0-9][a-z0-9._-]{0,159}$"},
        "utm_source": {"type": ["string", "null"], "maxLength": 200},
        "utm_medium": {"type": ["string", "null"], "maxLength": 200},
        "utm_campaign": {"type": ["string", "null"], "maxLength": 200},
        "utm_term": {"type": ["string", "null"], "maxLength": 200},
        "utm_content": {"type": ["string", "null"], "maxLength": 200},
        "consent": {"$ref": "#/$defs/consent"},
        "review_status": {"type": "string", "enum": ["new", "scored", "queued_for_review", "awaiting_documents", "in_human_review", "reviewed", "nurture", "closed", "rejected_invalid"]},
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"},
        "internal_context": {"$ref": "#/$defs/internalContext"}
      }
    },
    "applicant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["first_name", "last_name", "business_name", "email", "phone", "state"],
      "properties": {
        "first_name": {"type": "string", "minLength": 1, "maxLength": 120},
        "last_name": {"type": "string", "minLength": 1, "maxLength": 120},
        "business_name": {"type": "string", "minLength": 1, "maxLength": 180},
        "email": {"type": "string", "format": "email", "maxLength": 254},
        "phone": {"type": "string", "minLength": 7, "maxLength": 40},
        "state": {"type": "string", "minLength": 2, "maxLength": 40}
      }
    },
    "answers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["business_persona", "monthly_revenue", "time_in_business_months", "credit_score", "bank_status", "business_structure", "funding_purpose", "desired_funding_amount", "red_flags"],
      "properties": {
        "business_persona": {"type": "string", "minLength": 1, "maxLength": 120},
        "monthly_revenue": {"type": "number", "minimum": 0},
        "time_in_business_months": {"type": "integer", "minimum": 0, "maximum": 1200},
        "credit_score": {"type": "integer", "minimum": 0, "maximum": 850},
        "bank_status": {"type": "string", "enum": ["none", "low_inconsistent", "consistent", "strong_clean", "recent_nsfs"]},
        "business_structure": {"type": "string", "enum": ["none", "sole_prop", "entity_no_bank", "entity_with_bank", "entity_bank_ein_clean"]},
        "funding_purpose": {"type": "string", "enum": ["working_capital", "inventory_materials", "growth_marketing", "equipment_vehicle", "real_estate", "ecommerce_growth", "startup_launch", "debt_refi", "business_credit", "not_sure"]},
        "desired_funding_amount": {"type": "number", "minimum": 0},
        "red_flags": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "enum": ["none", "open_bankruptcy", "tax_lien", "recent_missed_payments", "recent_nsfs", "new_bank_account", "existing_daily_advance", "marketplace_suspended", "no_current_revenue"]}}
      }
    },
    "scoreResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "tier", "calculated_at", "engine_version"],
      "properties": {
        "score": {"type": "integer", "minimum": 0, "maximum": 100},
        "tier": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "label", "summary"],
          "properties": {
            "id": {"type": "string", "enum": ["highly_fundable", "fundable_review", "selective_programs", "not_ready_fixable"]},
            "label": {"type": "string", "minLength": 1, "maxLength": 160},
            "summary": {"type": "string", "minLength": 1, "maxLength": 800}
          }
        },
        "calculated_at": {"type": "string", "format": "date-time"},
        "engine_version": {"type": "string", "minLength": 1, "maxLength": 80}
      }
    },
    "fundingFamily": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "summary"],
      "properties": {
        "id": {"type": "string", "minLength": 2, "maxLength": 120},
        "label": {"type": "string", "minLength": 1, "maxLength": 160},
        "summary": {"type": "string", "minLength": 1, "maxLength": 800},
        "confidence": {"type": "string", "enum": ["low", "medium", "high"]}
      }
    },
    "documentItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "required"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 120},
        "label": {"type": "string", "minLength": 1, "maxLength": 240},
        "detail": {"type": ["string", "null"], "maxLength": 800},
        "required": {"type": "boolean"}
      }
    },
    "nextStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "owner", "status"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 120},
        "label": {"type": "string", "minLength": 1, "maxLength": 300},
        "owner": {"type": "string", "enum": ["applicant", "operator", "partner", "system"]},
        "status": {"type": "string", "enum": ["recommended", "queued", "in_progress", "completed", "skipped"]}
      }
    },
    "consent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contact", "privacy", "captured_at", "method", "text_version"],
      "properties": {
        "contact": {"type": "boolean", "const": true},
        "privacy": {"type": "boolean", "const": true},
        "captured_at": {"type": "string", "format": "date-time"},
        "method": {"type": "string", "enum": ["web_form", "widget", "gpt_action", "operator_entry", "api"]},
        "text_version": {"type": "string", "minLength": 1, "maxLength": 80}
      }
    },
    "attributionTouch": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "captured_at": {"type": ["string", "null"], "format": "date-time"},
        "partner_id": {"type": ["string", "null"], "maxLength": 120},
        "tracking_link_id": {"type": ["string", "null"], "maxLength": 120},
        "campaign_id": {"type": ["string", "null"], "maxLength": 120},
        "widget_id": {"type": ["string", "null"], "maxLength": 120},
        "source_url": {"type": ["string", "null"], "format": "uri", "maxLength": 2048},
        "utm_source": {"type": ["string", "null"], "maxLength": 200},
        "utm_medium": {"type": ["string", "null"], "maxLength": 200},
        "utm_campaign": {"type": ["string", "null"], "maxLength": 200},
        "utm_term": {"type": ["string", "null"], "maxLength": 200},
        "utm_content": {"type": ["string", "null"], "maxLength": 200}
      }
    },
    "internalContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "attribution_status": {"type": "string", "enum": ["direct", "unresolved", "validated", "rejected", "pending_partner_activation"]},
        "raw_attribution_hints": {"type": "object", "additionalProperties": {"type": ["string", "number", "boolean", "null"]}},
        "crm_record_ids": {"type": "object", "additionalProperties": {"type": "string"}},
        "persistence_targets": {"type": "array", "uniqueItems": true, "items": {"type": "string", "enum": ["notion", "google_sheets", "crm", "event_log", "queue"]}},
        "provider_match_ids": {"type": "array", "items": {"type": "string"}},
        "internal_notes": {"type": "string", "maxLength": 5000},
        "correlation_id": {"type": "string", "maxLength": 200},
        "payload_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "dedupe_status": {"type": "string", "enum": ["new", "exact_replay", "existing_lead_updated", "suspected_duplicate", "conflict"]}
      }
    }
  }
}
